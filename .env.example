# .env.example

# Database URL
DATABASE_URL=your_database_url_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Stripe Keys
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Cloudinary Keys
CLOUDINARY_URL=your_cloudinary_url_here

# API Port
API_PORT=3000
